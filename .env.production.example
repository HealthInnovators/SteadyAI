NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@db-host:5432/steadyai
DIRECT_URL=postgresql://user:password@db-host:5432/steadyai

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=nutrition-images

# Public domains
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
PUBLIC_BASE_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Web auth
# Supabase redirect URLs must include:
# - https://app.example.com/auth/callback
# - https://api.example.com/oauth/callback
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# TLS / Caddy
ACME_EMAIL=you@example.com

# MCP auth
APPS_MCP_API_KEY=

# AI providers
NUTRITION_AI_PROVIDER=gemini
LLM_PROVIDER=openai
LLM_TIMEOUT_MS=15000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
